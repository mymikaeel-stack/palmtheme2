<style>
.contact-wrap{min-height:calc(100vh - 110px);display:grid;grid-template-columns:1fr 1fr;}
.contact-left{background:var(--black);color:var(--cream);padding:100px 72px;display:flex;flex-direction:column;justify-content:space-between;}
.contact-label{font-size:10px;letter-spacing:4px;text-transform:uppercase;color:var(--accent);margin-bottom:24px;display:flex;align-items:center;gap:12px;}
.contact-label::before{content:"";width:32px;height:1px;background:var(--accent);}
.contact-title{font-family:"Playfair Display",serif;font-size:clamp(40px,5vw,72px);font-weight:900;line-height:.95;letter-spacing:-3px;margin-bottom:32px;}
.contact-title em{font-style:italic;font-weight:400;color:var(--accent);display:block;}
.contact-body{font-family:"Cormorant Garamond",serif;font-size:19px;font-weight:300;line-height:1.7;opacity:.65;max-width:360px;margin-bottom:48px;}
.contact-channels{display:flex;flex-direction:column;}
.contact-channel{border-top:1px solid rgba(255,255,255,.08);padding:20px 0;display:flex;justify-content:space-between;align-items:center;}
.contact-channel:last-child{border-bottom:1px solid rgba(255,255,255,.08);}
.contact-channel-label{font-size:10px;letter-spacing:3px;text-transform:uppercase;color:var(--accent);}
.contact-channel-value{font-family:"Cormorant Garamond",serif;font-size:17px;font-weight:400;opacity:.7;}
.contact-channel-value a{color:var(--cream);text-decoration:none;}
.contact-socials{display:flex;gap:20px;margin-top:60px;}
.contact-socials a{text-decoration:none;color:var(--cream);font-size:11px;font-weight:500;letter-spacing:2px;text-transform:uppercase;opacity:.4;transition:opacity .2s;}
.contact-socials a:hover{opacity:1;}
.contact-right{background:var(--warm-white);padding:100px 72px;display:flex;flex-direction:column;justify-content:center;}
.contact-form-title{font-family:"Playfair Display",serif;font-size:32px;font-weight:900;letter-spacing:-1px;margin-bottom:8px;}
.contact-form-sub{font-family:"Cormorant Garamond",serif;font-size:17px;font-weight:300;color:var(--text-muted);margin-bottom:40px;}
.contact-form{display:flex;flex-direction:column;gap:16px;}
.contact-form-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.contact-form input,.contact-form select,.contact-form textarea{width:100%;background:transparent;border:1px solid rgba(0,0,0,.18);color:var(--black);padding:15px 20px;font-size:13px;font-family:"Montserrat",sans-serif;outline:none;transition:border-color .2s;appearance:none;}
.contact-form input:focus,.contact-form select:focus,.contact-form textarea:focus{border-color:var(--black);}
.contact-form input::placeholder,.contact-form textarea::placeholder{opacity:.4;font-size:12px;}
.contact-form textarea{height:120px;resize:vertical;}
.contact-form select{cursor:pointer;background:transparent;}
.contact-form-btn{background:var(--black);color:var(--cream);border:none;padding:18px;font-size:11px;font-weight:700;letter-spacing:3px;text-transform:uppercase;cursor:pointer;transition:background .3s;width:100%;}
.contact-form-btn:hover{background:var(--accent);color:var(--black);}
.contact-form-note{font-size:10px;opacity:.4;letter-spacing:1px;text-align:center;}
.contact-success{display:none;text-align:center;padding:60px 20px;}
.contact-success.show{display:block;}
.contact-success-icon{font-size:56px;margin-bottom:20px;}
.contact-success h3{font-family:"Playfair Display",serif;font-size:30px;font-weight:700;margin-bottom:12px;}
.contact-success p{font-family:"Cormorant Garamond",serif;font-size:18px;color:var(--text-muted);line-height:1.6;}
@media(max-width:900px){
  .contact-wrap{grid-template-columns:1fr;}
  .contact-left,.contact-right{padding:60px 28px;}
}
@media(max-width:480px){.contact-form-row{grid-template-columns:1fr;}}
</style>
<section class="contact-wrap">
  <div class="contact-left">
    <div>
      <div class="contact-label">Get in Touch</div>
      <h1 class="contact-title">Say<br><em>Hello.</em></h1>
      <p class="contact-body">Whether you have a question about the collection, a collaboration idea, or just want to be part of what we're building — we'd love to hear from you.</p>
      <div class="contact-channels">
        <div class="contact-channel"><div class="contact-channel-label">Email</div><div class="contact-channel-value"><a href="mailto:hello@palmclub.ae">hello@palmclub.ae</a></div></div>
        <div class="contact-channel"><div class="contact-channel-label">WhatsApp</div><div class="contact-channel-value">+971 XX XXX XXXX</div></div>
        <div class="contact-channel"><div class="contact-channel-label">Based in</div><div class="contact-channel-value">Dubai, UAE</div></div>
        <div class="contact-channel"><div class="contact-channel-label">Shipping to</div><div class="contact-channel-value">UAE &amp; KSA</div></div>
      </div>
    </div>
    <div class="contact-socials">
      <a href="#">Instagram</a><a href="#">TikTok</a><a href="#">WhatsApp</a>
    </div>
  </div>
  <div class="contact-right">
    <div id="contact-form-area">
      <h2 class="contact-form-title">Send us a message</h2>
      <p class="contact-form-sub">We'll get back to you within 24 hours.</p>
      <form class="contact-form" id="contact-main-form">
        <div class="contact-form-row">
          <input type="text" placeholder="First name" required>
          <input type="text" placeholder="Last name" required>
        </div>
        <input type="email" placeholder="Email address" required>
        <input type="tel" placeholder="WhatsApp / Phone (optional)">
        <select><option value="" disabled selected>Subject</option><option>Question about the collection</option><option>Collaboration / Partnership</option><option>Press &amp; Media</option><option>Wholesale</option><option>Other</option></select>
        <textarea placeholder="Your message..."></textarea>
        <button type="submit" class="contact-form-btn">Send Message</button>
        <p class="contact-form-note">We reply within 24 hours, usually faster.</p>
      </form>
    </div>
    <div class="contact-success" id="contact-success">
      <div class="contact-success-icon">🌴</div>
      <h3>Message received.</h3>
      <p>We'll be in touch within 24 hours.</p>
    </div>
  </div>
</section>
{% schema %}{"name":"Contact Page","settings":[],"presets":[{"name":"Contact Page"}]}{% endschema %}